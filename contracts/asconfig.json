{
  "targets": {
    "vesting": {
      "outFile": "build/AegisVesting.wasm",
      "sourceMap": false,
      "use": "abort=src/vesting/index/abort"
    },
    "vault": {
      "outFile": "build/AegisVault.wasm",
      "sourceMap": false,
      "use": "abort=src/vault/index/abort"
    }
  },
  "options": {
    "optimizeLevel": 3,
    "shrinkLevel": 1,
    "converge": true,
    "noAssert": true,
    "runtime": "stub",
    "memoryBase": 0,
    "initialMemory": 1,
    "enable": [
      "sign-extension",
      "mutable-globals",
      "nontrapping-f2i",
      "bulk-memory",
      "simd",
      "reference-types",
      "multi-value"
    ],
    "transform": "@btc-vision/opnet-transform"
  }
}
